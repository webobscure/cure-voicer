{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "lib": ["ES2023", "DOM"],
    "types": ["node", "@playwright/test"]
  },
  "include": [
    "playwright.config.ts",
    "e2e/**/*.ts",
    "src/renderer/global.d.ts",
    "src/shared/contracts.ts",
    "src/shared/types/**/*.ts"
  ]
}
