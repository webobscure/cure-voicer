{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "lib": ["ES2023", "DOM"],
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "tests/**/*.ts",
    "src/shared/asr.ts",
    "src/main/audio/wav.ts",
    "src/renderer/audio-recorder.ts",
    "src/shared/contracts.ts",
    "src/shared/platform-shortcuts.ts",
    "src/shared/smart-correction.ts",
    "src/shared/transcript-postprocessor.ts",
    "src/shared/vocabulary.ts",
    "src/shared/types/**/*.ts",
    "src/shared/validation/**/*.ts",
    "src/modules/**/*.ts",
    "src/main/ipc/**/*.ts",
    "src/main/security/**/*.ts"
  ]
}
