{
  "compilerOptions": {
    "composite": true,
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "lib": ["ES2023", "DOM"],
    "types": ["node", "vitest/globals"]
  },
  "include": [
    "tests/**/*.ts",
    "src/main/audio/wav.ts",
    "src/renderer/audio-recorder.ts"
  ]
}
